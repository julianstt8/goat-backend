{
  "name": "goat-backend",
  "version": "1.0.0",
  "description": "API REST esqueleto para plantilla",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "nodemon --watch src --exec node src/server.js",
    "start": "node src/server.js",
    "seed:dev": "cross-env NODE_ENV=development node src/database/seeders/index.seed.js",
    "seed:prod": "cross-env NODE_ENV=production SEED_ALLOW_PROD=true node src/database/seeders/index.seed.js",
    "seed:csv": "node src/scripts/seedFromCsv.js",
    "seed:excel": "node src/scripts/seedFromExcel.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.10"
  }
}
